{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/root/*": [
        "./*"
      ],
      "@repo/commons/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "."
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}