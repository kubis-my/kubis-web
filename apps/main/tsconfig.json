{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/root/*": [
        "./*"
      ],
      "@/*": [
        "./app/*"
      ],
      "@/component/*": [
        "./components/*"
      ],
      "@/actions/*": [
        "./actions/*"
      ],
      "@/dict/*": [
        "./dict/*"
      ],
      "@/shadcn/*": [
        "../../packages/shadcn-ui/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}